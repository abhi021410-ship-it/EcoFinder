{
  "manifest_version": 3,
  "name": "EcoFindr (Hackathon Demo)",
  "version": "0.0.1",
  "description": "Shows an eco-score badge and popup (demo).",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://*.amazon.in/*",
    "https://*.amazon.com/*",
    "https://www.flipkart.com/*",
    "https://*.flipkart.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.in/*/dp/*",
        "https://*.amazon.com/*/dp/*",
        "https://www.flipkart.com/*/p/*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
